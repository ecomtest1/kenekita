<div id="cookie-banner" class="fixed bottom-0 left-0 right-0 z-50 bg-white border-t border-stone-warm/10 shadow-[0_-4px_20px_rgba(0,0,0,0.04)] transform translate-y-full transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-10 py-6">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
      <div class="max-w-2xl">
        <h3 class="font-serif text-lg font-medium text-charcoal mb-2">Utilizziamo i cookie</h3>
        <p class="text-sm text-stone-warm leading-relaxed">
          Utilizziamo cookie tecnici e, con il tuo consenso, cookie di profilazione per migliorare la tua esperienza e offrirti contenuti personalizzati. 
          <a href="/cookie-policy" class="text-terracotta hover:underline">Maggiori informazioni</a>.
        </p>
      </div>
      <div class="flex gap-3 shrink-0">
        <button 
          id="cookie-reject" 
          class="px-5 py-2.5 text-sm font-medium text-charcoal border border-stone-warm/20 rounded-full hover:bg-stone-warm/5 transition-colors"
        >
          Rifiuta
        </button>
        <button 
          id="cookie-accept" 
          class="px-5 py-2.5 text-sm font-medium text-white bg-terracotta rounded-full hover:bg-terracotta-dark transition-colors"
        >
          Accetta tutti
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  const cookieBanner = document.getElementById('cookie-banner');
  const cookieAccept = document.getElementById('cookie-accept');
  const cookieReject = document.getElementById('cookie-reject');
  
  const consent = localStorage.getItem('cookie-consent');
  
  if (!consent) {
    setTimeout(() => {
      cookieBanner?.classList.remove('translate-y-full');
    }, 1500);
  }
  
  function hideBanner() {
    cookieBanner?.classList.add('translate-y-full');
    setTimeout(() => {
      cookieBanner?.classList.add('hidden');
    }, 500);
  }
  
  cookieAccept?.addEventListener('click', () => {
    localStorage.setItem('cookie-consent', 'accepted');
    hideBanner();
  });
  
  cookieReject?.addEventListener('click', () => {
    localStorage.setItem('cookie-consent', 'rejected');
    hideBanner();
  });
</script>

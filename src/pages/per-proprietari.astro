---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    title: 'Prezzi che si Adattano',
    description: 'Analizziamo il mercato ogni giorno per trovare il prezzo perfetto: neanche troppo basso da svenderti, ne troppo alto da far rimanere vuota.',
    icon: 'M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605',
  },
  {
    title: 'Pensiamo a Tutto Noi',
    description: 'Pulizie, chiavi, check-in alle 2 di notte, luce che non funziona. Non dovrai preoccuparti di nulla: la tua casa e in mani sicure.',
    icon: 'M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z',
  },
  {
    title: 'Zero Carte da Compilare',
    description: 'Tasse di soggiorno, contratti, normative, comunicazioni al comune. La burocrazia ci annoia, ma la gestiamo noi per te.',
    icon: 'M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z',
  },
  {
    title: 'Foto che Fan Innamorare',
    description: 'Sappiamo esattamente cosa cercano gli ospiti. Le nostre foto e descrizioni fanno battere il cuore e prenotare subito.',
    icon: 'M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z',
  },
];

const stats = [
  { value: '21', label: 'Proprietà gestite' },
  { value: '+40%', label: 'Incremento medio entrate' },
  { value: '4.9', label: 'Rating medio ospiti' },
  { value: '24/7', label: 'Assistenza' },
];
---

<Layout 
  title="Per Proprietari | KENEKITA"
  description="Affida la gestione della tua proprietà in Sardegna a KENEKITA. Gestione completa con massimi rendimenti e zero preoccupazioni."
>
  <section class="pt-32 pb-16 md:pt-40 md:pb-24">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
      <div class="max-w-2xl mb-16">
        <p class="text-terracotta text-sm uppercase tracking-[0.2em] font-medium mb-4">Per Proprietari</p>
        <h1 class="font-serif text-4xl md:text-6xl text-charcoal font-medium mb-6">
          La tua casa merita di brillare
        </h1>
        <p class="text-stone-warm text-lg leading-relaxed">
          Hai un angolo di paradiso in Sardegna e vuoi condividerlo con il mondo? 
          Noi ci occupiamo di tutto, tu ricevi solo i benefici. E qualche foto bellissima dei tuoi ospiti sorridenti.
        </p>
      </div>
      
      <!-- Stats -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 mb-20">
        {stats.map(stat => (
          <div class="p-8 rounded-2xl bg-sand border border-stone-warm/10 text-center">
            <p class="font-serif text-4xl text-terracotta font-medium mb-2">{stat.value}</p>
            <p class="text-stone-warm text-sm">{stat.label}</p>
          </div>
        ))}
      </div>
      
      <!-- Services -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-20">
        {services.map(service => (
          <div class="p-10 rounded-2xl bg-white border border-stone-warm/10 hover:border-terracotta/20 transition-all duration-300 group">
            <div class="w-14 h-14 rounded-xl bg-terracotta/5 text-terracotta flex items-center justify-center mb-6 group-hover:bg-terracotta group-hover:text-white transition-all duration-300">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={service.icon} />
              </svg>
            </div>
            <h3 class="font-serif text-2xl text-charcoal font-medium mb-3">{service.title}</h3>
            <p class="text-stone-warm leading-relaxed">{service.description}</p>
          </div>
        ))}
      </div>
      
      <!-- CTA Form -->
      <div class="p-10 md:p-16 rounded-[2rem] bg-charcoal text-center">
        <h2 class="font-serif text-3xl md:text-4xl text-white font-medium mb-4">
          Raccontaci della tua casa
        </h2>
        <p class="text-sand-dark/70 mb-10 max-w-lg mx-auto">
          Ogni casa ha una storia. Noi vogliamo conoscere la tua. Scrivici e ci vediamo per un caffe virtuale (o reale, se sei in zona).
        </p>
        
        <form action="https://api.web3forms.com/submit" method="POST" class="max-w-xl mx-auto space-y-4 text-left">
          <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY" />
          <input type="hidden" name="redirect" value="https://kenekita.it/grazie" />
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm text-sand-dark/70 mb-2">Nome</label>
              <input 
                type="text" 
                name="name" 
                required
                class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-white/30 focus:outline-none focus:border-terracotta-light transition-colors"
                placeholder="Mario"
              />
            </div>
            <div>
              <label class="block text-sm text-sand-dark/70 mb-2">Cognome</label>
              <input 
                type="text" 
                name="surname" 
                required
                class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-white/30 focus:outline-none focus:border-terracotta-light transition-colors"
                placeholder="Rossi"
              />
            </div>
          </div>
          <div>
            <label class="block text-sm text-sand-dark/70 mb-2">Email</label>
            <input 
              type="email" 
              name="email" 
              required
              class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-white/30 focus:outline-none focus:border-terracotta-light transition-colors"
              placeholder="mario@esempio.it"
            />
          </div>
          <div>
            <label class="block text-sm text-sand-dark/70 mb-2">Telefono</label>
            <input 
              type="tel" 
              name="phone"
              class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-white/30 focus:outline-none focus:border-terracotta-light transition-colors"
              placeholder="+39 123 456 7890"
            />
          </div>
          <div>
            <label class="block text-sm text-sand-dark/70 mb-2">Località proprietà</label>
            <input 
              type="text" 
              name="location"
              class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-white/30 focus:outline-none focus:border-terracotta-light transition-colors"
              placeholder="Porto Cervo"
            />
          </div>
          <div>
            <label class="block text-sm text-sand-dark/70 mb-2">Messaggio</label>
            <textarea 
              name="message" 
              rows="4"
              class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-white/30 focus:outline-none focus:border-terracotta-light transition-colors resize-none"
              placeholder="Descrivi la tua proprietà..."
            ></textarea>
          </div>
          <button 
            type="submit"
            class="w-full py-4 bg-terracotta text-white font-medium rounded-full hover:bg-terracotta-light transition-all duration-300 hover:scale-[0.98]"
          >
            Invia richiesta
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>

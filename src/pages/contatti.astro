---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Contatti | KENEKITA"
  description="Contatta KENEKITA per prenotazioni e informazioni. Siamo a Porto Cervo, Sardegna."
>
  <section class="pt-32 pb-16 md:pt-40 md:pb-24">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <!-- Info -->
        <div>
          <p class="text-terracotta text-sm uppercase tracking-[0.2em] font-medium mb-4">Contatti</p>
          <h1 class="font-serif text-4xl md:text-5xl text-charcoal font-medium mb-8">
            Siamo qui per te
          </h1>
          <p class="text-stone-warm text-lg leading-relaxed mb-12">
            Hai domande su una proprietà o vuoi affidare la gestione della tua casa? 
            Scrivici e ti risponderemo entro 24 ore.
          </p>
          
          <div class="space-y-8">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-terracotta/5 text-terracotta flex items-center justify-center shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
                </svg>
              </div>
              <div>
                <h3 class="font-medium text-charcoal mb-1">Email</h3>
                <a href="mailto:info@kenekita.it" class="text-stone-warm hover:text-terracotta transition-colors">info@kenekita.it</a>
              </div>
            </div>
            
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-terracotta/5 text-terracotta flex items-center justify-center shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-medium text-charcoal mb-1">Telefono</h3>
                <a href="tel:+390789123456" class="text-stone-warm hover:text-terracotta transition-colors">+39 0789 123 456</a>
              </div>
            </div>
            
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-terracotta/5 text-terracotta flex items-center justify-center shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-medium text-charcoal mb-1">Indirizzo</h3>
                <p class="text-stone-warm">Via Roma, 123<br/>07021 Porto Cervo (OT)<br/>Sardegna, Italia</p>
              </div>
            </div>
          </div>
          
          <!-- Social -->
          <div class="mt-12 pt-8 border-t border-stone-warm/10">
            <h3 class="font-medium text-charcoal mb-4">Seguici</h3>
            <div class="flex gap-4">
              <a href="#" class="w-12 h-12 rounded-full bg-sand flex items-center justify-center text-charcoal hover:bg-terracotta hover:text-white transition-all" aria-label="Instagram">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              </a>
              <a href="#" class="w-12 h-12 rounded-full bg-sand flex items-center justify-center text-charcoal hover:bg-terracotta hover:text-white transition-all" aria-label="Facebook">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
            </div>
          </div>
        </div>
        
        <!-- Form -->
        <div class="p-8 md:p-10 rounded-2xl bg-white border border-stone-warm/10 shadow-[0_20px_40px_-15px_rgba(0,0,0,0.05)]">
          <h2 class="font-serif text-2xl text-charcoal font-medium mb-6">Scrivici</h2>
          <form action="https://api.web3forms.com/submit" method="POST" class="space-y-4">
            <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY" />
            <input type="hidden" name="redirect" value="https://kenekita.it/grazie" />
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm text-stone-warm mb-2">Nome</label>
                <input 
                  type="text" 
                  name="name" 
                  required
                  class="w-full px-4 py-3 bg-sand border border-stone-warm/10 rounded-xl text-charcoal placeholder-stone-warm/40 focus:outline-none focus:border-terracotta transition-colors"
                  placeholder="Mario"
                />
              </div>
              <div>
                <label class="block text-sm text-stone-warm mb-2">Cognome</label>
                <input 
                  type="text" 
                  name="surname" 
                  required
                  class="w-full px-4 py-3 bg-sand border border-stone-warm/10 rounded-xl text-charcoal placeholder-stone-warm/40 focus:outline-none focus:border-terracotta transition-colors"
                  placeholder="Rossi"
                />
              </div>
            </div>
            <div>
              <label class="block text-sm text-stone-warm mb-2">Email</label>
              <input 
                type="email" 
                name="email" 
                required
                class="w-full px-4 py-3 bg-sand border border-stone-warm/10 rounded-xl text-charcoal placeholder-stone-warm/40 focus:outline-none focus:border-terracotta transition-colors"
                placeholder="mario@esempio.it"
              />
            </div>
            <div>
              <label class="block text-sm text-stone-warm mb-2">Oggetto</label>
              <select 
                name="subject"
                class="w-full px-4 py-3 bg-sand border border-stone-warm/10 rounded-xl text-charcoal focus:outline-none focus:border-terracotta transition-colors"
              >
                <option value="">Seleziona...</option>
                <option value="prenotazione">Informazioni prenotazione</option>
                <option value="proprietario">Sono un proprietario</option>
                <option value="collaborazione">Collaborazione</option>
                <option value="altro">Altro</option>
              </select>
            </div>
            <div>
              <label class="block text-sm text-stone-warm mb-2">Messaggio</label>
              <textarea 
                name="message" 
                rows="5"
                required
                class="w-full px-4 py-3 bg-sand border border-stone-warm/10 rounded-xl text-charcoal placeholder-stone-warm/40 focus:outline-none focus:border-terracotta transition-colors resize-none"
                placeholder="Il tuo messaggio..."
              ></textarea>
            </div>
            <button 
              type="submit"
              class="w-full py-4 bg-terracotta text-white font-medium rounded-full hover:bg-terracotta-dark transition-all duration-300 hover:scale-[0.98]"
            >
              Invia messaggio
            </button>
          </form>
        </div>
      </div>
      
      <!-- Map placeholder -->
      <div class="mt-16 aspect-[21/9] rounded-2xl bg-sand border border-stone-warm/10 overflow-hidden flex items-center justify-center">
        <div class="text-center">
          <div class="w-16 h-16 rounded-full bg-terracotta/10 text-terracotta flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
            </svg>
          </div>
          <p class="text-stone-warm">Mappa interattiva in fase di integrazione</p>
          <p class="text-sm text-stone-warm/60 mt-1">Porto Cervo, Sardegna</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

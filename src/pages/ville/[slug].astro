---
import Layout from '../../layouts/Layout.astro';
import RoomCard from '../../components/RoomCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const rooms = await getCollection('rooms');
  return rooms.map(room => ({
    params: { slug: room.data.slug },
    props: { room },
  }));
}

const { room } = Astro.props;
const { title, description, heroImage, gallery = [], bookingLink, location, guests, bedrooms, bathrooms, metaTitle, metaDescription } = room.data;

const allImages = heroImage ? [heroImage, ...gallery] : gallery;

const allRooms = await getCollection('rooms');
const relatedRooms = allRooms.filter(r => r.data.slug !== room.data.slug).slice(0, 3);
---

<Layout 
  title={metaTitle || `${title} | KENEKITA`}
  description={metaDescription || `Scopri ${title} in Sardegna. Ville e appartamenti selezionati per una vacanza indimenticabile.`}
  image={heroImage}
  type="website"
>
  <!-- Hero Carousel -->
  <section class="relative pt-24 md:pt-28">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
      <div class="mb-6">
        <nav class="flex items-center gap-2 text-sm text-stone-warm mb-6">
          <a href="/" class="hover:text-charcoal transition-colors">Home</a>
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
          <a href="/ville" class="hover:text-charcoal transition-colors">Ville</a>
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
          <span class="text-charcoal">{title}</span>
        </nav>
      </div>
    </div>

    {/* Carousel Auto-Play */}
    {allImages.length > 0 && (
      <div class="room-hero-carousel relative w-full overflow-hidden group" data-total={allImages.length}>
        <div class="carousel-hero-track flex transition-transform duration-700 ease-out" style={`width: ${allImages.length * 100}%`}>
          {allImages.map((img: string, i: number) => (
            <div class="relative cursor-zoom-in lightbox-trigger" style={`width: ${100 / allImages.length}%`} data-index={i}>
              <div class="aspect-[16/9] md:aspect-[21/9] mx-6 lg:mx-10 rounded-2xl overflow-hidden bg-sand-dark">
                <img 
                  src={img} 
                  alt={`${title} - foto ${i + 1}`}
                  class="w-full h-full object-cover"
                  loading={i === 0 ? "eager" : "lazy"}
                />
              </div>
            </div>
          ))}
        </div>

        {/* Frecce navigazione */}
        {allImages.length > 1 && (
          <>
            <button class="carousel-prev absolute left-4 md:left-8 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white/90 backdrop-blur-sm shadow-lg flex items-center justify-center text-charcoal hover:bg-white transition-all opacity-0 group-hover:opacity-100 z-20" aria-label="Foto precedente">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/></svg>
            </button>
            <button class="carousel-next absolute right-4 md:right-8 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white/90 backdrop-blur-sm shadow-lg flex items-center justify-center text-charcoal hover:bg-white transition-all opacity-0 group-hover:opacity-100 z-20" aria-label="Foto successiva">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
            </button>
            
            {/* Indicatori + contatore */}
            <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex items-center gap-3 z-20 bg-charcoal/60 backdrop-blur-sm px-4 py-2 rounded-full">
              <span class="text-white text-sm font-medium carousel-counter">1 / {allImages.length}</span>
            </div>
          </>
        )}
      </div>
    )}
  </section>

  <!-- Info Header -->
  <section class="py-10 md:py-14">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
      {location && (
        <p class="text-terracotta text-sm uppercase tracking-[0.2em] font-medium mb-3">{location}</p>
      )}
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl text-charcoal font-medium mb-6">{title}</h1>
      
      <div class="flex flex-wrap gap-6 text-sm text-stone-warm">
        {guests && (
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>
            </svg>
            {guests} ospiti
          </span>
        )}
        {bedrooms && (
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>
            </svg>
            {bedrooms} camere da letto
          </span>
        )}
        {bathrooms && (
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/>
            </svg>
            {bathrooms} bagni
          </span>
        )}
      </div>
    </div>
  </section>

  <!-- Galleria completa con lightbox -->
  {allImages.length > 0 && (
    <section class="pb-16 md:pb-24">
      <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
        <h2 class="font-serif text-2xl text-charcoal font-medium mb-8">Galleria</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4">
          {allImages.map((img: string, i: number) => (
            <button 
              class="lightbox-trigger aspect-[4/3] rounded-xl overflow-hidden bg-sand-dark group relative cursor-zoom-in"
              data-index={i}
              aria-label={`Vedi foto ${i + 1}`}
            >
              <img 
                src={img} 
                alt={`${title} - foto ${i + 1}`}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-charcoal/0 group-hover:bg-charcoal/20 transition-colors duration-300 flex items-center justify-center">
                <svg class="w-8 h-8 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607zM10.5 7.5v6m3-3h-6"/>
                </svg>
              </div>
            </button>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Description + CTA -->
  <section class="pb-16 md:pb-24">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        <div class="lg:col-span-7">
          <div class="prose prose-lg max-w-none">
            {description ? (
              <Fragment set:html={description} />
            ) : (
              <div class="text-stone-warm text-lg leading-relaxed space-y-6">
                <p>
                  Benvenuto in <strong class="text-charcoal">{title}</strong>, uno dei gioielli della nostra collezione in Sardegna. 
                  Ogni angolo di questa proprietà è stato pensato per offrirti un soggiorno indimenticabile, 
                  tra il profumo del mare e il silenzio della macchia mediterranea.
                </p>
                <p>
                  Svegliati con il sole che entra dalle finestre, prepara il caffe in cucina e goditi 
                  la colazione in terrazza. Le giornate qui scorrono lente, accompagnate solo dal rumore 
                  delle cicale e della brezza marina.
                </p>
                <p>
                  Il team KENEKITA ha curato personalmente ogni dettaglio: dalla biancheria profumata 
                  ai consigli sui ristoranti e le spiagge meno affollate. Perché una vacanza vera 
                  inizia quando ti senti a casa, ovunque tu sia.
                </p>
              </div>
            )}
          </div>
        </div>
        <div class="lg:col-span-4 lg:col-start-9">
          <div class="sticky top-32 p-8 rounded-2xl bg-white border border-stone-warm/10 shadow-[0_20px_40px_-15px_rgba(0,0,0,0.05)]">
            <h3 class="font-serif text-2xl text-charcoal font-medium mb-4">Prenota il tuo soggiorno</h3>
            <p class="text-stone-warm text-sm mb-6 leading-relaxed">
              Verifica subito la disponibilita e prenota direttamente. I nostri partner garantiscono 
              le migliori tariffe e condizioni flessibili.
            </p>
            {bookingLink ? (
              <a 
                href={bookingLink}
                target="_blank"
                rel="noopener noreferrer"
                class="w-full py-4 bg-terracotta text-white text-center font-medium rounded-full hover:bg-terracotta-dark transition-all duration-300 block mb-3"
              >
                Verifica disponibilita
              </a>
            ) : (
              <a 
                href="/contatti"
                class="w-full py-4 bg-terracotta text-white text-center font-medium rounded-full hover:bg-terracotta-dark transition-all duration-300 block mb-3"
              >
                Richiedi informazioni
              </a>
            )}
            <div class="mt-6 pt-6 border-t border-stone-warm/10 space-y-3">
              <p class="text-xs text-stone-warm flex items-center gap-2">
                <svg class="w-4 h-4 text-macchia" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Tariffe piu basse garantite
              </p>
              <p class="text-xs text-stone-warm flex items-center gap-2">
                <svg class="w-4 h-4 text-macchia" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Assistenza durante il soggiorno
              </p>
              <p class="text-xs text-stone-warm flex items-center gap-2">
                <svg class="w-4 h-4 text-macchia" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Cancellazione flessibile
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Related -->
  {relatedRooms.length > 0 && (
    <section class="py-16 md:py-24 bg-sand border-t border-stone-warm/10">
      <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
        <h2 class="font-serif text-3xl text-charcoal font-medium mb-3">Altre proprieta che amerai</h2>
        <p class="text-stone-warm mb-10 max-w-xl">Ogni casa racconta una storia diversa. Scopri quella che fa per te.</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {relatedRooms.map((r, i) => (
            <RoomCard room={r} index={i} />
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Lightbox */}
  <div id="lightbox" class="fixed inset-0 z-[100] bg-charcoal/95 backdrop-blur-sm hidden opacity-0 transition-opacity duration-300">
    <button id="lightbox-close" class="absolute top-6 right-6 z-20 w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-white/20 transition-colors" aria-label="Chiudi">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
    
    <button id="lightbox-prev" class="absolute left-4 md:left-8 top-1/2 -translate-y-1/2 z-20 w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-white/20 transition-colors" aria-label="Precedente">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/></svg>
    </button>
    
    <button id="lightbox-next" class="absolute right-4 md:right-8 top-1/2 -translate-y-1/2 z-20 w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-white/20 transition-colors" aria-label="Successiva">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
    </button>
    
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-20 text-white/70 text-sm">
      <span id="lightbox-counter">1 / {allImages.length}</span>
    </div>
    
    <div class="w-full h-full flex items-center justify-center p-4 md:p-16">
      <img id="lightbox-img" src="" alt="" class="max-w-full max-h-full object-contain rounded-lg" />
    </div>
  </div>

  <script define:vars={{ images: allImages }}>
    // --- Hero Carousel ---
    (function() {
      const carousel = document.querySelector('.room-hero-carousel');
      if (!carousel) return;
      const track = carousel.querySelector('.carousel-hero-track');
      const total = parseInt(carousel.dataset.total || '0');
      if (total <= 1 || !track) return;

      const counter = carousel.querySelector('.carousel-counter');
      const prevBtn = carousel.querySelector('.carousel-prev');
      const nextBtn = carousel.querySelector('.carousel-next');
      let current = 0;
      let interval = null;

      function update() {
        track.style.transform = `translateX(-${current * (100 / total)}%)`;
        if (counter) counter.textContent = `${current + 1} / ${total}`;
      }

      function next() {
        current = (current + 1) % total;
        update();
      }

      function prev() {
        current = (current - 1 + total) % total;
        update();
      }

      function start() {
        if (interval) clearInterval(interval);
        interval = setInterval(next, 4000);
      }
      function stop() {
        if (interval) clearInterval(interval);
      }

      carousel.addEventListener('mouseenter', stop);
      carousel.addEventListener('mouseleave', start);
      prevBtn?.addEventListener('click', (e) => { e.stopPropagation(); prev(); stop(); });
      nextBtn?.addEventListener('click', (e) => { e.stopPropagation(); next(); stop(); });

      update();
      start();
    })();

    // --- Lightbox ---
    (function() {
      const lightbox = document.getElementById('lightbox');
      const lightboxImg = document.getElementById('lightbox-img');
      const counter = document.getElementById('lightbox-counter');
      if (!lightbox || !lightboxImg) return;

      let currentIndex = 0;

      function open(index) {
        currentIndex = index;
        lightboxImg.src = images[index];
        lightboxImg.alt = `Foto ${index + 1}`;
        if (counter) counter.textContent = `${index + 1} / ${images.length}`;
        lightbox.classList.remove('hidden');
        requestAnimationFrame(() => lightbox.classList.remove('opacity-0'));
        document.body.style.overflow = 'hidden';
      }

      function close() {
        lightbox.classList.add('opacity-0');
        setTimeout(() => {
          lightbox.classList.add('hidden');
          document.body.style.overflow = '';
        }, 300);
      }

      function next() {
        currentIndex = (currentIndex + 1) % images.length;
        open(currentIndex);
      }

      function prev() {
        currentIndex = (currentIndex - 1 + images.length) % images.length;
        open(currentIndex);
      }

      document.querySelectorAll('.lightbox-trigger').forEach(el => {
        el.addEventListener('click', () => {
          const idx = parseInt(el.dataset.index || '0');
          open(idx);
        });
      });

      document.getElementById('lightbox-close')?.addEventListener('click', close);
      document.getElementById('lightbox-next')?.addEventListener('click', (e) => { e.stopPropagation(); next(); });
      document.getElementById('lightbox-prev')?.addEventListener('click', (e) => { e.stopPropagation(); prev(); });

      lightbox.addEventListener('click', (e) => {
        if (e.target === lightbox || e.target === lightboxImg) close();
      });

      document.addEventListener('keydown', (e) => {
        if (lightbox.classList.contains('hidden')) return;
        if (e.key === 'Escape') close();
        if (e.key === 'ArrowRight') next();
        if (e.key === 'ArrowLeft') prev();
      });
    })();
  </script>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import RoomCard from '../components/RoomCard.astro';
import { getCollection } from 'astro:content';

const rooms = await getCollection('rooms');

const servicesGuests = [
  {
    title: 'Benvenuto Premium',
    description: 'Ti accogliamo personalmente e ti guidiamo nella tua casa vacanza e nei dintorni.',
    icon: 'M15 19l-7-7 7-7',
  },
  {
    title: 'Pulizia Impeccabile',
    description: 'Ogni proprietà è preparata meticolosamente per garantire massimo comfort e igiene.',
    icon: 'M5 13l4 4L19 7',
  },
  {
    title: 'Supporto 24/7',
    description: 'Un team dedicato sempre disponibile per qualsiasi necessità durante il tuo soggiorno.',
    icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z',
  },
  {
    title: 'Sicurezza Garantita',
    description: 'Proprietà certificate e verificate per una vacanza senza pensieri.',
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  },
];

const servicesOwners = [
  {
    title: 'Gestione Prenotazioni',
    description: 'Ottimizziamo i tuoi introiti con strategie di pricing dinamico e marketing professionale.',
  },
  {
    title: 'Manutenzione Completa',
    description: 'Ci occupiamo di tutto: pulizie, check-in/out, piccole riparazioni e gestione emergenze.',
  },
  {
    title: 'Burocrazia Semplificata',
    description: 'Gestiamo contratti, tasse di soggiorno e conformità alle normative locali.',
  },
  {
    title: 'Marketing Professionale',
    description: 'Foto professionali, testi accattivanti e presenza sui migliori portali turistici.',
  },
];

const testimonials = [
  {
    name: 'Marco e Laura',
    role: 'Ospiti, Agosto 2024',
    text: 'Una vacanza da sogno! La villa era ancora più bella delle foto, pulitissima e con una vista mozzafiato. Il team di Kenekita ci ha accolto con un calore incredibile.',
  },
  {
    name: 'Giovanni Rossi',
    role: 'Proprietario',
    text: 'Affidare la mia villa a Kenekita è stata la scelta migliore. Gestiscono tutto in modo professionale e le mie entrate sono aumentate del 40%. Consigliatissimo!',
  },
  {
    name: 'Sophie & Thomas',
    role: 'Ospiti, Luglio 2024',
    text: 'Abbiamo passato la settimana più bella in Sardegna! L\'appartamento era perfetto, la posizione incredibile e il team sempre disponibile. Torneremo sicuramente!',
  },
];

const platforms = [
  { name: 'Booking.com', logo: '/platforms/booking.svg' },
  { name: 'Airbnb', logo: '/platforms/airbnb.svg' },
  { name: 'Expedia', logo: '/platforms/expedia.svg' },
  { name: 'Vrbo', logo: '/platforms/vrbo.svg' },
];
---

<Layout 
  title="KENEKITA | Co-Hosting & Property Management in Sardegna"
  description="Ville e appartamenti selezionati in Sardegna per una vacanza autentica. Gestione completa della proprietà per proprietari."
>
  <!-- Hero Section -->
  <section class="relative min-h-[100dvh] flex items-center overflow-hidden">
    <div class="absolute inset-0">
      <img 
        src="/images/hero-sardegna.jpg" 
        alt="Costa Smeralda, Sardegna"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-charcoal/40 via-charcoal/20 to-charcoal/60"></div>
    </div>
    
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 lg:px-10 py-32 w-full">
      <div class="max-w-3xl">
        <p class="text-white/80 text-sm uppercase tracking-[0.2em] font-medium mb-6 animate-fade-in-up">
          Ville e Appartamenti in Sardegna
        </p>
        <h1 class="font-serif text-5xl md:text-7xl lg:text-8xl text-white font-medium mb-8 leading-[0.95] animate-fade-in-up animate-delay-100 text-balance">
          Il tuo sogno<br/>sardo inizia qui
        </h1>
        <p class="text-white/80 text-lg md:text-xl max-w-xl mb-10 leading-relaxed animate-fade-in-up animate-delay-200">
          Per chi cerca la vacanza perfetta, per chi vuole trasformare la propria casa in un'opportunità.
        </p>
        <div class="flex flex-wrap gap-4 animate-fade-in-up animate-delay-300">
          <a 
            href="/ville" 
            class="group inline-flex items-center gap-3 px-8 py-4 bg-white text-charcoal font-medium rounded-full hover:bg-sand transition-all duration-300"
          >
            <span>Prenota</span>
            <span class="w-8 h-8 rounded-full bg-charcoal/5 flex items-center justify-center group-hover:bg-charcoal group-hover:text-white transition-all">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
              </svg>
            </span>
          </a>
          <a 
            href="/per-proprietari" 
            class="group inline-flex items-center gap-3 px-8 py-4 bg-white/10 backdrop-blur-sm text-white border border-white/20 font-medium rounded-full hover:bg-white/20 transition-all duration-300"
          >
            <span>Collabora</span>
            <span class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center group-hover:bg-white/20 transition-all">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
              </svg>
            </span>
          </a>
        </div>
      </div>
    </div>
    
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
      </svg>
    </div>
  </section>

  <!-- Featured Rooms -->
  <section class="py-24 md:py-32 bg-sand">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16">
        <div>
          <p class="text-terracotta text-sm uppercase tracking-[0.2em] font-medium mb-4">Le nostre proprietà</p>
          <h2 class="font-serif text-4xl md:text-5xl text-charcoal font-medium">Trova la tua casa vacanza</h2>
        </div>
        <a href="/ville" class="group inline-flex items-center gap-2 text-charcoal font-medium hover:text-terracotta transition-colors">
          <span>Vedi tutte</span>
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {rooms.slice(0, 6).map((room, i) => (
          <RoomCard room={room} index={i} />
        ))}
      </div>
    </div>
  </section>

  <!-- Services Guests -->
  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
        <div>
          <p class="text-terracotta text-sm uppercase tracking-[0.2em] font-medium mb-4">Per gli Ospiti</p>
          <h2 class="font-serif text-4xl md:text-5xl text-charcoal font-medium mb-6">
            Una vacanza autentica e indimenticabile
          </h2>
          <p class="text-stone-warm text-lg leading-relaxed mb-10">
            Proprietà selezionate in Sardegna per un'esperienza unica, con servizi pensati per il tuo benessere.
          </p>
          <ul class="space-y-4 mb-10">
            <li class="flex items-start gap-3">
              <span class="w-5 h-5 rounded-full bg-macchia/10 text-macchia flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              </span>
              <span class="text-charcoal">Proprietà verificate e ben mantenute</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-5 h-5 rounded-full bg-macchia/10 text-macchia flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              </span>
              <span class="text-charcoal">Assistenza 24/7 durante il soggiorno</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-5 h-5 rounded-full bg-macchia/10 text-macchia flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              </span>
              <span class="text-charcoal">Migliori tariffe garantite</span>
            </li>
          </ul>
        </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {servicesGuests.map(service => (
            <div class="p-8 rounded-2xl bg-sand border border-stone-warm/10 hover:border-terracotta/20 transition-colors duration-300 group">
              <div class="w-12 h-12 rounded-xl bg-terracotta/5 text-terracotta flex items-center justify-center mb-5 group-hover:bg-terracotta group-hover:text-white transition-all duration-300">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={service.icon} />
                </svg>
              </div>
              <h3 class="font-serif text-xl font-medium text-charcoal mb-3">{service.title}</h3>
              <p class="text-stone-warm text-sm leading-relaxed">{service.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- About Preview -->
  <section class="py-24 md:py-32 bg-sand">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-5">
          <div class="relative">
            <div class="aspect-[4/5] rounded-[2rem] overflow-hidden">
              <img src="/images/about-team.jpg" alt="Team KENEKITA" class="w-full h-full object-cover" />
            </div>
            <div class="absolute -bottom-8 -right-8 bg-white rounded-2xl p-8 shadow-[0_20px_40px_-15px_rgba(0,0,0,0.08)] hidden md:block">
              <p class="font-serif text-4xl text-terracotta font-medium mb-1">2015</p>
              <p class="text-stone-warm text-sm">Anno di fondazione</p>
            </div>
          </div>
        </div>
        <div class="lg:col-span-6 lg:col-start-7">
          <p class="text-terracotta text-sm uppercase tracking-[0.2em] font-medium mb-4">Chi Siamo</p>
          <h2 class="font-serif text-4xl md:text-5xl text-charcoal font-medium mb-6">
            Il tuo partner di fiducia
          </h2>
          <p class="text-stone-warm text-lg leading-relaxed mb-8">
            Il tuo partner di fiducia per gli affitti turistici in Sardegna. Professionalità, esperienza e passione per l'ospitalità dal 2015.
          </p>
          <a href="/chi-siamo" class="group inline-flex items-center gap-3 px-8 py-4 bg-charcoal text-white font-medium rounded-full hover:bg-charcoal-light transition-all duration-300">
            <span>Scopri di più</span>
            <span class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center group-hover:bg-white/20 transition-all">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
              </svg>
            </span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Owners -->
  <section class="py-24 md:py-32 bg-charcoal text-sand-dark">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <p class="text-terracotta-light text-sm uppercase tracking-[0.2em] font-medium mb-4">Per i Proprietari</p>
        <h2 class="font-serif text-4xl md:text-5xl text-white font-medium mb-6">
          Gestione completa, zero preoccupazioni
        </h2>
        <p class="text-sand-dark/70 text-lg">
          Gestione completa della proprietà con massimi rendimenti e zero preoccupazioni.
        </p>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {servicesOwners.map(service => (
          <div class="p-8 rounded-2xl bg-white/5 border border-white/10 hover:bg-white/10 hover:border-white/20 transition-all duration-300">
            <h3 class="font-serif text-xl font-medium text-white mb-3">{service.title}</h3>
            <p class="text-sand-dark/60 text-sm leading-relaxed">{service.description}</p>
          </div>
        ))}
      </div>
      
      <div class="mt-16 text-center">
        <div class="inline-flex flex-col sm:flex-row items-center gap-6 p-8 rounded-2xl bg-white/5 border border-white/10">
          <div class="text-left">
            <h3 class="font-serif text-2xl text-white font-medium mb-2">Possiedi una proprietà in Sardegna?</h3>
            <p class="text-sand-dark/60">Affida la gestione a noi e inizia a guadagnare senza pensieri</p>
          </div>
          <a 
            href="/per-proprietari" 
            class="shrink-0 px-8 py-4 bg-terracotta text-white font-medium rounded-full hover:bg-terracotta-light transition-all duration-300 hover:scale-[0.98]"
          >
            Inizia ora
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <p class="text-terracotta text-sm uppercase tracking-[0.2em] font-medium mb-4">Testimonianze</p>
        <h2 class="font-serif text-4xl md:text-5xl text-charcoal font-medium">Cosa dicono di noi</h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {testimonials.map(t => (
          <div class="p-8 rounded-2xl bg-sand border border-stone-warm/10">
            <div class="flex gap-1 mb-6">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-terracotta" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <p class="text-charcoal leading-relaxed mb-6">"{t.text}"</p>
            <div>
              <p class="font-medium text-charcoal">{t.name}</p>
              <p class="text-stone-warm text-sm">{t.role}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Platforms -->
  <section class="py-16 md:py-24 bg-sand border-t border-stone-warm/10">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
      <p class="text-center text-stone-warm text-sm uppercase tracking-[0.2em] font-medium mb-10">
        Disponibili sulle principali piattaforme
      </p>
      <div class="flex flex-wrap justify-center items-center gap-12 md:gap-16">
        {platforms.map(p => (
          <div class="text-2xl font-serif text-stone-warm/40 hover:text-stone-warm transition-colors cursor-default">
            {p.name}
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
